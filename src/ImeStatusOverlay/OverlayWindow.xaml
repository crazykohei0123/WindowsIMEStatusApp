<Window x:Class="ImeStatusOverlay.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ShowActivated="False"
        Focusable="False"
        SizeToContent="WidthAndHeight"
        Opacity="0">
    <Border Background="#B3000000"
            CornerRadius="28"
            Padding="72,36"
            BorderBrush="#33FFFFFF"
            BorderThickness="1">
        <TextBlock x:Name="StateText"
                   Text="IME ON"
                   FontSize="96"
                   FontWeight="Bold"
                   FontFamily="Segoe UI, Yu Gothic UI, Meiryo UI"
                   Foreground="#4ADE80"
                   TextAlignment="Center" />
    </Border>
</Window>